# Parliamentary AI Monitor - Configuration
# Copy this file to .env and fill in your values

# Required: Gemini API Key (get from https://ai.google.dev)
GEMINI_API_KEY=

# Optional: Google Chat Webhook URL (leave empty for terminal-only mode)
# Get from: Chat Space → Settings → Apps & integrations → Webhooks → Add webhook
GOOGLE_CHAT_WEBHOOK_URL=

# Optional: Model name (default: gemini-3.1-flash-live-preview)
GEMINI_MODEL=gemini-3.1-flash-live-preview

# Optional: System prompt file path (default: system_prompt.txt)
SYSTEM_PROMPT_PATH=system_prompt.txt
